<% content_for :title, "Notes" %>

<% if user_signed_in? %>

  <div class="max-w-6xl mx-auto px-6 py-8">

    <div class="mb-8 flex items-center justify-between">
      <div>
        <h1 class="text-3xl font-bold text-gray-900">
          My Notes
        </h1>

        <p class="mt-1 text-gray-500">
          <%= pluralize(@notes.count, "note") %>
        </p>
      </div>

      <%= link_to "New Note",
        new_note_path,
        class: "rounded-lg bg-black px-5 py-2.5 text-sm font-medium text-white transition hover:bg-gray-800" %>
    </div>

    <% if @notes.any? %>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">

        <% @notes.each do |note| %>

          <div class="relative group">

            <%= link_to note_path(note),
              class: "block h-full rounded-2xl border border-gray-200 bg-white p-6 shadow-sm transition duration-200 hover:-translate-y-1 hover:shadow-xl" do %>

              <%= render note %>

            <% end %>

            <div class="absolute top-4 right-4 z-10 flex gap-2">

              <%= link_to edit_note_path(note),
                class: "rounded-lg border border-gray-200 bg-white p-2 shadow hover:bg-gray-100" do %>
                ✏️
              <% end %>

              <%= button_to note,
                method: :delete,
                data: { turbo_confirm: "Delete this note?" },
                class: "rounded-lg border border-red-200 bg-white p-2 text-red-600 shadow hover:bg-red-50" do %>
                🗑️
              <% end %>

            </div>

          </div>

        <% end %>

      </div>

    <% else %>

      <div class="rounded-2xl border-2 border-dashed border-gray-300 bg-gray-50 py-20 text-center">

        <div class="mb-4 text-6xl">
          📝
        </div>

        <h2 class="text-2xl font-semibold text-gray-800">
          No notes yet
        </h2>

        <p class="mt-2 text-gray-500">
          Create your first note to get started.
        </p>

        <%= link_to "Create Note",
          new_note_path,
          class: "mt-6 inline-block rounded-lg bg-black px-6 py-3 text-white hover:bg-gray-800" %>

      </div>

    <% end %>

  </div>

<% else %>

  <%= render "home/landing" %>

<% end %>