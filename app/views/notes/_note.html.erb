<div id="<%= dom_id note %>" class="flex h-full flex-col">

  <span
    class="mb-4 h-3 w-3 rounded-full"
    style="background-color: <%= note.color.presence || '#d1d5db' %>;">
  </span>

  <h2 class="text-xl font-semibold text-gray-900">
    <%= note.title %>
  </h2>

  <p class="mt-3 flex-1 text-gray-600">
    <%= truncate(note.description, length: 140) %>
  </p>

  <p class="mt-6 text-sm text-gray-400">
    Updated <%= time_ago_in_words(note.updated_at) %> ago
  </p>

</div>