<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Auranotes" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Auranotes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>
    <%= favicon_link_tag "editing.png", type: "image/png" %>
    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
      <% flash.each do |type, message| %>
        <div class="mx-auto mt-4 flex max-w-2xl items-center justify-between rounded-lg px-4 py-3 shadow
          <%= type == 'notice' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %>">
          <span><%= message %></span>
          <button onclick="this.parentElement.remove()" class="ml-4 text-xl font-bold opacity-60 hover:opacity-100">
            &times;
          </button>
        </div>
      <% end %>
      <% unless controller_name == 'registrations' ||controller_name == 'sessions' ||controller_name == 'passwords' %>
          <%= render 'layouts/navbar' %>
      <% end %>
      <%= yield %>
  </body>
</html>
