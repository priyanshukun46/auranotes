<div class="min-h-screen bg-gray-100 flex items-center justify-center px-4">
  <div class="w-full max-w-md bg-white rounded-3xl shadow-xl p-10">

    <div class="text-center mb-8">
      <h1 class="text-4xl font-semibold text-gray-900">Sign in</h1>
      <p class="mt-2 text-gray-500">
        Sign in to your account
      </p>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>

      <div class="mb-5">
        <%= f.email_field :email,
          autofocus: true,
          autocomplete: "email",
          placeholder: "Email",
          class: "w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-blue-500 focus:ring-2 focus:ring-blue-500 outline-none transition" %>
      </div>

      <div class="mb-5">
        <%= f.password_field :password,
          autocomplete: "current-password",
          placeholder: "Password",
          class: "w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-blue-500 focus:ring-2 focus:ring-blue-500 outline-none transition" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="flex items-center mb-6">
          <%= f.check_box :remember_me, class: "rounded border-gray-300" %>
          <%= f.label :remember_me, class: "ml-2 text-sm text-gray-600" %>
        </div>
      <% end %>

      <%= f.submit "Sign In",
        class: "w-full bg-black hover:bg-gray-800 text-white font-medium py-3 rounded-xl transition cursor-pointer" %>

    <% end %>

    <div class="mt-6 text-center text-sm text-gray-500">
      <%= render "devise/shared/links" %>
    </div>

  </div>
</div>