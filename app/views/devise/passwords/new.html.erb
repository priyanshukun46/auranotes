<div class="min-h-screen flex items-center justify-center bg-white px-4">
  <div class="w-full max-w-md bg-white rounded-3xl shadow-lg p-10">

    <div class="text-center mb-8">
      <h1 class="text-4xl font-bold text-gray-900">
        Forgot Password?
      </h1>

      <p class="mt-3 text-gray-500">
        Enter your email address and we'll send you a password reset link.
      </p>
    </div>

    <%= form_for(resource,
                 as: resource_name,
                 url: password_path(resource_name),
                 html: { method: :post, class: "space-y-6" }) do |f| %>

      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.email_field :email,
          autofocus: true,
          autocomplete: "email",
          placeholder: "Email address",
          class: "w-full rounded-xl border border-gray-300 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-black focus:border-black" %>
      </div>

      <%= f.submit "Send reset instructions",
        class: "w-full rounded-xl bg-black py-3 text-white font-semibold hover:bg-gray-800 transition" %>

    <% end %>

    <div class="mt-8 text-center text-sm text-gray-600">
      <%= render "devise/shared/links" %>
    </div>

  </div>
</div>